# VaaniSetu Environment Variables
# Copy this to .env and fill in your keys

# Groq API (free at https://groq.com) — used for LLM summarization
GROQ_API_KEY=your_groq_api_key_here

# Twilio (free trial at https://twilio.com) — WhatsApp SMS fallback
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# App settings
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# Audio output directory
AUDIO_DIR=/tmp/vaanisetu_audio
